<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:paddingTop="2dp"
    android:paddingBottom="2dp"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:duplicateParentState="true"
    >
    <CheckBox
        android:id="@+id/applicationSelectedCheckBox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:focusable="false"
        android:clickable="false"
        />
    <ImageView
        android:id="@+id/applicationIconImageView"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="10dp"
        />
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        >
        <TextView
            android:id="@+id/applicationLabelTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:clickable="false"
            android:focusable="false"
            android:textColor="?bluelineconsoleBaseTextColor"
            android:textStyle="bold"
            />
        <TextView
            android:id="@+id/applicationPackageNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:clickable="false"
            android:focusable="false"
            android:textColor="?bluelineconsoleBaseTextColor"
            android:textSize="12sp"
            />
    </LinearLayout>
</LinearLayout>
