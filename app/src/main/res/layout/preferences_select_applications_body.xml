<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".applicationMain.PreferencesSelectApplicationsActivity"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical"
    >
    <EditText
        android:id="@+id/applicationSearchEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="请输入应用名称或包名搜索"
        android:padding="12dp"
        android:inputType="text"
        android:maxLines="1"
        android:background="?android:attr/selectableItemBackground"
        />
    <TextView
        android:id="@+id/noResultsTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="未找到匹配的应用"
        android:gravity="center"
        android:padding="20dp"
        android:textColor="?android:attr/textColorSecondary"
        android:visibility="gone"
        />
    <ListView
        android:id="@+id/applicationList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="?android:colorBackground"
        android:animateLayoutChanges="true"
        />
    <Button
        android:id="@+id/applicationsDoneButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/button_save"
        android:layout_margin="3dp"
        android:drawableStart="@android:drawable/ic_menu_save"
        />
</LinearLayout>
